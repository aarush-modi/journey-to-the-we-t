  npcName: King Modi
  npcSprite: {fileID: 4723107735738678597, guid: fb351d54b2f3bba4c978d378f0ae8b1c, type: 3}
  dialogue:
  - '*You feel a overwhelming surge of greed pulse through your body.*\n*Suddenly, even all the money in the world is not enough for you.*'
  - '*King Modi rolls out of his pile of 1-Yen notes to address you.*'
  - 'MONEY MONEY MONEY.\nI LOOOOOVE MONEY.'
  - I AM THE RICHEST MAN ON EARTH, KING MODI.
  - I POSSESS THE RED PACKET YOU DESIRE, NINJA OF GREED.
  - I SEE YOU HAVE SOMETHING I DESIRE.
  - '*Modi eyes the 1-Yen coin in your hand.*'
  - TELL ME, ARE YOU A GAMBLING MAN?
  - LET US GAMBLE.
  - '*Modi takes all of your money anyways.*'
  dialogueTime: []
  typingSpeed: 0.05
  voiceSounds: {fileID: 0}
